# API base URL for the dashboard.
# Normal local dev: point directly at the API server.
# Tunnel / mobile dev: set to /api-proxy so Vite's proxy forwards requests through the same origin,
# avoiding iOS ITP blocking cross-origin auth cookies.
VITE_API_BASE_URL=http://localhost:3001

# Cloudflare tunnel hostname for mobile device testing (see afonsocrg/dev/mobile_debugging.md).
# Set this to the tunnel host (no protocol, no path) when running `pnpm dev:network`.
# Leave unset for normal local development.
# Example: TUNNEL_HOST=your-tunnel-name.trycloudflare.com
# Note: Cloudflare tunnel URLs are ephemeral — update this each session.
TUNNEL_HOST=
