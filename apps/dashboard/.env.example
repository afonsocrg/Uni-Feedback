# =============================================================================
# DASHBOARD ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and update with your values.

# API base URL. For normal local dev, point directly at the API server.
VITE_API_BASE_URL=http://localhost:3001

# Website URL. Used to build links and QR codes pointing to the student-facing site.
# Falls back to replacing port 5174 → 5173 in the current origin if not set.
VITE_WEBSITE_URL=http://localhost:3000

# =============================================================================
# MOBILE / TUNNEL DEV MODE  (`pnpm dev:network`)
# =============================================================================
# When testing on a physical device via Cloudflare tunnel, create a separate
# .env.network file (gitignored) — it is only loaded by `pnpm dev:network`.
#
# .env.network contents:
#
#   # Route the dashboard through Vite's proxy so dashboard and API share the
#   # same origin, avoiding iOS ITP blocking cross-origin auth cookies.
#   VITE_API_BASE_URL=/api-proxy
#
#   # Your Cloudflare tunnel hostname (no protocol, no path).
#   # Cloudflare tunnel URLs are ephemeral — update this each session.
#   TUNNEL_HOST=your-tunnel-name.trycloudflare.com
#
# See afonsocrg/dev/mobile_debugging.md for the full tunnel setup guide.
